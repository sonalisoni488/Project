{
	"info": {
		"_postman_id": "waste2resource-api",
		"name": "Waste2Resource API",
		"description": "API collection for Waste-to-Resource Marketplace platform",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123\",\n  \"role\": \"seller\",\n  \"location\": \"New York, NY\",\n  \"phone\": \"+1-555-0123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						}
					}
				},
				{
					"name": "Login User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth/me",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "me"]
						}
					}
				}
			]
		},
		{
			"name": "Listings",
			"item": [
				{
					"name": "Get All Listings",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/listings?wasteType=Plastic&minPrice=10&maxPrice=100",
							"host": ["{{baseUrl}}"],
							"path": ["listings"],
							"query": [
								{
									"key": "wasteType",
									"value": "Plastic"
								},
								{
									"key": "minPrice",
									"value": "10"
								},
								{
									"key": "maxPrice",
									"value": "100"
								}
							]
						}
					}
				},
				{
					"name": "Get Listing by ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/listings/{{listingId}}",
							"host": ["{{baseUrl}}"],
							"path": ["listings", "{{listingId}}"]
						}
					}
				},
				{
					"name": "Create Listing",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "multipart/form-data"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "image",
									"type": "file",
									"src": "/path/to/image.jpg"
								},
								{
									"key": "wasteType",
									"value": "Plastic"
								},
								{
									"key": "weight",
									"value": "15.5"
								},
								{
									"key": "description",
									"value": "Clean plastic bottles and containers"
								},
								{
									"key": "location",
									"value": "New York, NY"
								},
								{
									"key": "finalPrice",
									"value": "8.50"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/listings",
							"host": ["{{baseUrl}}"],
							"path": ["listings"]
						}
					}
				},
				{
					"name": "Show Interest",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/listings/{{listingId}}/interest",
							"host": ["{{baseUrl}}"],
							"path": ["listings", "{{listingId}}", "interest"]
						}
					}
				}
			]
		},
		{
			"name": "Transactions",
			"item": [
				{
					"name": "Get Transactions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/transactions?role=buyer&status=completed",
							"host": ["{{baseUrl}}"],
							"path": ["transactions"],
							"query": [
								{
									"key": "role",
									"value": "buyer"
								},
								{
									"key": "status",
									"value": "completed"
								}
							]
						}
					}
				},
				{
					"name": "Create Transaction",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"listingId\": \"{{listingId}}\",\n  \"paymentMethod\": \"bank_transfer\",\n  \"pickupAddress\": \"123 Main St, New York, NY 10001\",\n  \"notes\": \"Please call before pickup\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/transactions",
							"host": ["{{baseUrl}}"],
							"path": ["transactions"]
						}
					}
				},
				{
					"name": "Update Transaction Status",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"status\": \"completed\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/transactions/{{transactionId}}/status",
							"host": ["{{baseUrl}}"],
							"path": ["transactions", "{{transactionId}}", "status"]
						}
					}
				}
			]
		},
		{
			"name": "AI Service",
			"item": [
				{
					"name": "Classify Waste",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "multipart/form-data"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": "/path/to/waste-image.jpg"
								}
							]
						},
						"url": {
							"raw": "{{aiServiceUrl}}/predict",
							"host": ["{{aiServiceUrl}}"],
							"path": ["predict"]
						}
					}
				},
				{
					"name": "Predict Price",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"waste_type\": \"Plastic\",\n  \"weight\": 15.5,\n  \"location\": \"New York, NY\"\n}"
						},
						"url": {
							"raw": "{{aiServiceUrl}}/price",
							"host": ["{{aiServiceUrl}}"],
							"path": ["price"]
						}
					}
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api",
			"type": "string"
		},
		{
			"key": "aiServiceUrl",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "your_jwt_token_here",
			"type": "string"
		},
		{
			"key": "listingId",
			"value": "listing_id_here",
			"type": "string"
		},
		{
			"key": "transactionId",
			"value": "transaction_id_here",
			"type": "string"
		}
	]
}
